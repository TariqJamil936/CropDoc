# Copy this file to .env (or set these in backend/.env, which is also read) and fill in real values.

# Required for the AI Chat page (Detect Disease works without it).
OPENAI_API_KEY=sk-your-key-here

# Optional — enables Claude as the final diagnosis synthesizer (reviews the CNN's and
# OpenAI's independent findings + the photo). Without it, OpenAI's diagnosis is used
# directly as primary.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional overrides — defaults shown.
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
ANTHROPIC_MODEL=claude-sonnet-5

# Placeholder for future session-signing use — not currently a security boundary (see SECURITY.md).
APP_SECRET=change-me-to-a-random-string
